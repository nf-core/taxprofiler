nextflow_pipeline {

    name "Test alternative preprocessing"
    script "../main.nf"
    tag "pipeline"
    tag "test_alternativepreprocessing"
    profile "test_alternativepreprocessing"

    test("-profile test_alternativepreprocessing") {

        when {
            params {
                outdir = "$outputDir"
            }
        }

        then {
            def stable_name_all               = getAllFilesFromDir(params.outdir              , relative: true , includeDir: true, ignore: ['pipeline_info/*.{html,json,txt}'])
            def stable_content_adapterremoval = getAllFilesFromDir("$outputDir/adapterremoval", relative: false, includeDir: false, ignore: null, ignoreFile: 'tests/.nftignore', include: ['*', '**/*'])
            def stable_content_bbduk          = getAllFilesFromDir("$outputDir/bbduk"         , relative: false, includeDir: false, ignore: null, ignoreFile: 'tests/.nftignore', include: ['*','**/*'])
            def stable_content_bowtie2       = getAllFilesFromDir("$outputDir/bowtie2"        , relative: false, includeDir: false, ignore: null, ignoreFile: 'tests/.nftignore', include: ['*','**/*'])
            def stable_content_fastqc        = getAllFilesFromDir("$outputDir/fastqc"         , relative: false, includeDir: false, ignore: null, ignoreFile: 'tests/.nftignore', include: ['*','**/*'])
            def stable_content_filtlong      = getAllFilesFromDir("$outputDir/filtlong"       , relative: false, includeDir: false, ignore: null, ignoreFile: 'tests/.nftignore', include: ['*','**/*'])
            def stable_content_kaiju         = getAllFilesFromDir("$outputDir/kaiju"          , relative: false, includeDir: false, ignore: null, ignoreFile: 'tests/.nftignore', include: ['*','**/*'])
            def stable_content_kraken2       = getAllFilesFromDir("$outputDir/kraken2"        , relative: false, includeDir: false, ignore: null, ignoreFile: 'tests/.nftignore', include: ['*','**/*'])
            def stable_content_porechop      = getAllFilesFromDir("$outputDir/porechop"       , relative: false, includeDir: false, ignore: null, ignoreFile: 'tests/.nftignore', include: ['*','**/*'])
            def stable_content_samtools      = getAllFilesFromDir("$outputDir/samtools"       , relative: false, includeDir: false, ignore: null, ignoreFile: 'tests/.nftignore', include: ['*','**/*'])

            assertAll(
                { assert workflow.success},
                { assert snapshot(
                    // pipeline versions.yml file for multiqc from which Nextflow version is removed because we test pipelines on multiple Nextflow versions
                    removeNextflowVersion("$outputDir/pipeline_info/nf_core_taxprofiler_software_mqc_versions.yml"),
                ).match() },

                { assert new File("$outputDir/pipeline_info/nf_core_taxprofiler_software_mqc_versions.yml").exists() },
                { assert new File("$outputDir/multiqc/multiqc_report.html").exists() },

                { assert snapshot ( stable_name_all ).match("all_files") },

                // adapterremoval
                { assert snapshot ( stable_content_adapterremoval ).match("adapterremoval") },

                // bbduk
                { assert snapshot ( stable_content_bbduk ).match("bbduk") },
                
                // bowtie2
                { assert snapshot ( stable_content_bowtie2 ).match("bowtie2") },

                // fastqc
                { assert snapshot ( stable_content_fastqc ).match("fastqc") },

                // filtlong
                { assert snapshot ( stable_content_filtlong ).match("filtlong") },

                // kaiju
                { assert snapshot ( stable_content_kaiju ).match("kaiju") },

                // Kraken2
                { assert snapshot ( stable_content_kraken2 ).match("kraken2") },

                // porechop
                { assert snapshot ( stable_content_porechop ).match("porechop") },

                // samtools
                { assert snapshot ( stable_content_samtools ).match("samtools") },
            )

        }
    }
}
