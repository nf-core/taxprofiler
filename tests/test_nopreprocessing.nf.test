nextflow_pipeline {

    name "Test pipeline"
    script "../main.nf"
    tag "pipeline"
    tag "test_nopreprocessing"
    profile "test_nopreprocessing"

    test("-profile test_nopreprocessing") {

        when {
            params {
                outdir = "$outputDir"
            }
        }

        then {

            def stable_name_all = getAllFilesFromDir(params.outdir, relative: true, includeDir: true, ignore: ['pipeline_info/*.{html,json,txt}'])
            def stable_content_bracken = getAllFilesFromDir(params.outdir, relative: false, includeDir: false, include: ["bracken/**"], ignoreFile: 'tests/.nftignore')
            // centrifuge:  partly unstable files, see custom assertions
            // diamond:  partly unstable files, see custom assertions
            // fastqc: all files unstable
            def stable_content_ganon = getAllFilesFromDir(params.outdir, relative: false, includeDir: false, include: ["ganon/**"], ignoreFile: 'tests/.nftignore')
            // kaiju:  partly unstable files, see custom assertions
            def stable_content_kmcp = getAllFilesFromDir(params.outdir, relative: false, includeDir: false, include: ["kmcp/**"], ignoreFile: 'tests/.nftignore')
            // kraken2:  partly unstable files, see custom assertions
            // krona: all files unstable
            def stable_content_melon = getAllFilesFromDir(params.outdir, relative: false, includeDir: false, include: ["melon/**"], ignoreFile: 'tests/.nftignore')
            // metacache:  partly unstable files, see custom assertions
            // metaphlan: all files unstable
            // multiqc: all unstable files, see custom assertion
            // pipeline_info: all unstable files, see custom assertion
            def stable_content_sylph = getAllFilesFromDir(params.outdir, relative: false, includeDir: false, include: ["sylph/**"], ignoreFile: 'tests/.nftignore')

            assertAll(
                { assert workflow.success},
                { assert snapshot(
                    // pipeline versions.yml file for multiqc from which Nextflow version is removed because we test pipelines on multiple Nextflow versions
                    removeNextflowVersion("$outputDir/pipeline_info/nf_core_taxprofiler_software_mqc_versions.yml"),
                ).match() },

                { assert new File("$outputDir/pipeline_info/nf_core_taxprofiler_software_mqc_versions.yml").exists() },
                { assert new File("$outputDir/multiqc/multiqc_report.html").exists() },
                { assert snapshot ( stable_name_all ).match("all_files") },

                // bracken
                { assert snapshot ( stable_content_bracken ).match("bracken") },

                // centrifuge
                { assert snapshot(
                        getAllFilesFromDir("$outputDir/centrifuge", include: ['**/*.centrifuge.report.txt']).collect{file -> file.getName() + " contains string 'Homo sapiens': " + file.text.contains("Homo sapiens") },
                        getAllFilesFromDir("$outputDir/centrifuge", include: ['**/*.centrifuge.results.txt']).collect{file -> file.getName() + " contains string '4392': " + file.text.contains("4392") },
                        getAllFilesFromDir("$outputDir/centrifuge", include: ['**/*.centrifuge.txt']).collect{file -> file.getName() + " contains string 'Homo sapiens': " + file.text.contains("Homo sapiens") },
                    ).match("centrifuge")
                },

                // diamond
                { assert snapshot(
                        getAllFilesFromDir("$outputDir/diamond", include: ['**/*diamond.log']).collect{file -> file.getName() + ' contains string:' + file.text.contains("queries aligned") },
                        file("$outputDir/diamond/db1/2611_ERR5766174_db1.diamond.tsv").getName() + " contains string 'ERR5766174.77':" + file("$outputDir/diamond/db1/2611_ERR5766174_db1.diamond.tsv").text.contains("ERR5766174.77"),
                        file("$outputDir/diamond/db1/2612_ERR5766176_B_db1.diamond.tsv").getName() + " contains string 'ERR5766176.629950':" + file("$outputDir/diamond/db1/2612_ERR5766176_B_db1.diamond.tsv").text.contains("ERR5766176.629950"),
                        file("$outputDir/diamond/db1/2612_ERR5766176_db1.diamond.tsv").getName() + " contains string 'ERR5766176.629950':" + file("$outputDir/diamond/db1/2612_ERR5766176_db1.diamond.tsv").text.contains("ERR5766176.629950"),
                        file("$outputDir/diamond/db1/2612_ERR5766180_db1.diamond.tsv").getName() + " contains string 'ERR5766180.800099':" + file("$outputDir/diamond/db1/2612_ERR5766180_db1.diamond.tsv").text.contains("ERR5766180.800099"),
                        file("$outputDir/diamond/db1/2613_ERR5766181_db1.diamond.tsv").getName() + " contains string 'ERR5766181.537534':" + file("$outputDir/diamond/db1/2613_ERR5766181_db1.diamond.tsv").text.contains("ERR5766181.537534"),
                        file("$outputDir/diamond/db2/2614_ERR3201952_db2.diamond.tsv").getName() + " contains string 'ERR3201952.2880089':" + file("$outputDir/diamond/db2/2614_ERR3201952_db2.diamond.tsv").text.contains("ERR3201952.2880089"),
                        file("$outputDir/diamond/db2/ERR3201952_ERR3201952_db2.diamond.tsv").getName() + " contains string 'ERR3201952.3883730':" + file("$outputDir/diamond/db2/ERR3201952_ERR3201952_db2.diamond.tsv").text.contains("ERR3201952.3883730"),
                        file("$outputDir/diamond/db3/2611_ERR5766174_db3.diamond.tsv").getName() + " contains string 'ERR5766174.787821':" +  file("$outputDir/diamond/db3/2611_ERR5766174_db3.diamond.tsv").text.contains("ERR5766174.787821"),
                        file("$outputDir/diamond/db3/2612_ERR5766176_B_db3.diamond.tsv").getName() + " contains string 'ERR5766176.629950':" + file("$outputDir/diamond/db3/2612_ERR5766176_B_db3.diamond.tsv").text.contains("ERR5766176.629950"),
                        file("$outputDir/diamond/db3/2612_ERR5766176_db3.diamond.tsv").getName() + " contains string 'ERR5766176.629950':" + file("$outputDir/diamond/db3/2612_ERR5766176_db3.diamond.tsv").text.contains("ERR5766176.629950"),
                        file("$outputDir/diamond/db3/2612_ERR5766180_db3.diamond.tsv").getName() + " contains string 'ERR5766180.801451':" + file("$outputDir/diamond/db3/2612_ERR5766180_db3.diamond.tsv").text.contains("ERR5766180.801451"),
                        file("$outputDir/diamond/db3/2613_ERR5766181_db3.diamond.tsv").getName() + " contains string 'ERR5766181.537534':" +file("$outputDir/diamond/db3/2613_ERR5766181_db3.diamond.tsv").text.contains("ERR5766181.537534"),
                        file("$outputDir/diamond/db3/2614_ERR3201952_db3.diamond.tsv").getName() + " contains string 'ERR3201952.1276975':" +file("$outputDir/diamond/db3/2614_ERR3201952_db3.diamond.tsv").text.contains("ERR3201952.1276975"),
                        file("$outputDir/diamond/db3/ERR3201952_ERR3201952_db3.diamond.tsv").getName() + " contains string 'ERR3201952.1276975':" +file("$outputDir/diamond/db3/ERR3201952_ERR3201952_db3.diamond.tsv").text.contains("ERR3201952.1276975"),
                    ).match("diamond")
                },

                // ganon
                { assert snapshot(
                        getAllFilesFromDir("$outputDir/ganon", include: ['**/*.ganon.log']).collect { file -> file.getName() + " contains string 'entries reported':" + file.text.contains("entries reported")},
                        getAllFilesFromDir("$outputDir/ganon", include: ['**/*.ganon.rep']).collect { file -> file.getName() + " contains string 'total_classified':" + file.text.contains("total_classified")},
                        getAllFilesFromDir("$outputDir/ganon", include: ['**/*.tre']).collect { file -> file.getName() + ' contains string:' + file.text.contains("root")},
                        stable_content_ganon
                    ).match("ganon")
                },
                // kaiju
                { assert snapshot( file("$outputDir/kaiju/db5/2611_ERR5766174_db5.kaijutable.txt").getName() + " contains string '787877':" +file("$outputDir/kaiju/db5/2611_ERR5766174_db5.kaijutable.txt").text.contains("787877"),
                                file("$outputDir/kaiju/db5/2611_ERR5766174_db5.kaiju.tsv").getName()+ " contains string 'ERR5766174.787872':" + file("$outputDir/kaiju/db5/2611_ERR5766174_db5.kaiju.tsv").text.contains("ERR5766174.787872"),
                                file("$outputDir/kaiju/db5/2612_ERR5766176_B_db5.kaijutable.txt").getName()+ " contains string '10239':" + file("$outputDir/kaiju/db5/2612_ERR5766176_B_db5.kaijutable.txt").text.contains("10239"),
                                file("$outputDir/kaiju/db5/2612_ERR5766176_B_db5.kaiju.tsv").getName() + " contains string 'ERR5766176.632056':" + file("$outputDir/kaiju/db5/2612_ERR5766176_B_db5.kaiju.tsv").text.contains("ERR5766176.632056"),
                                file("$outputDir/kaiju/db5/2612_ERR5766176_db5.kaijutable.txt").getName()+ " contains string '10239':" + file("$outputDir/kaiju/db5/2612_ERR5766176_db5.kaijutable.txt").text.contains("10239"),
                                file("$outputDir/kaiju/db5/2612_ERR5766176_db5.kaiju.tsv").getName() + " contains string 'ERR5766176.632059':" + file("$outputDir/kaiju/db5/2612_ERR5766176_db5.kaiju.tsv").text.contains("ERR5766176.632059"),
                                file("$outputDir/kaiju/db5/2612_ERR5766180_db5.kaijutable.txt").getName()+ " contains string '10239':" + file("$outputDir/kaiju/db5/2612_ERR5766180_db5.kaijutable.txt").text.contains("10239"),
                                file("$outputDir/kaiju/db5/2612_ERR5766180_db5.kaiju.tsv").getName() + " contains string 'ERR5766180.801529':" + file("$outputDir/kaiju/db5/2612_ERR5766180_db5.kaiju.tsv").text.contains("ERR5766180.801529"),
                                file("$outputDir/kaiju/db5/2613_ERR5766181_db5.kaijutable.txt").getName() + " contains string '10239':" + file("$outputDir/kaiju/db5/2613_ERR5766181_db5.kaijutable.txt").text.contains("10239"),
                                file("$outputDir/kaiju/db5/2613_ERR5766181_db5.kaiju.tsv").getName() + " contains string 'ERR5766181.537543':" + file("$outputDir/kaiju/db5/2613_ERR5766181_db5.kaiju.tsv").text.contains("ERR5766181.537543"),
                                file("$outputDir/kaiju/db6/2614_ERR3201952_db6.kaijutable.txt").getName() + " contains string '10239':" + file("$outputDir/kaiju/db6/2614_ERR3201952_db6.kaijutable.txt").text.contains("10239"),
                                file("$outputDir/kaiju/db6/2614_ERR3201952_db6.kaiju.tsv").getName() + " contains string 'ERR3201952.3733937':" + file("$outputDir/kaiju/db6/2614_ERR3201952_db6.kaiju.tsv").text.contains("ERR3201952.3733937"),
                                file("$outputDir/kaiju/db6/ERR3201952_ERR3201952_db6.kaijutable.txt").getName() + " contains string 'Viruses':" + file("$outputDir/kaiju/db6/ERR3201952_ERR3201952_db6.kaijutable.txt").text.contains("Viruses"),
                                file("$outputDir/kaiju/db6/ERR3201952_ERR3201952_db6.kaiju.tsv").getName() + " contains string 'ERR3201952.3733937':" + file("$outputDir/kaiju/db6/ERR3201952_ERR3201952_db6.kaiju.tsv").text.contains("ERR3201952.3733937"),
                                file("$outputDir/kaiju/db7/2611_ERR5766174_db7.kaijutable.txt").getName() + " contains string '10239':" + file("$outputDir/kaiju/db7/2611_ERR5766174_db7.kaijutable.txt").text.contains("10239"),
                                file("$outputDir/kaiju/db7/2611_ERR5766174_db7.kaiju.tsv").getName() + " contains string 'ERR5766174.787876':" + file("$outputDir/kaiju/db7/2611_ERR5766174_db7.kaiju.tsv").text.contains("ERR5766174.787876"),
                                file("$outputDir/kaiju/db7/2612_ERR5766176_B_db7.kaijutable.txt").getName()+ " contains string '10239':" + file("$outputDir/kaiju/db7/2612_ERR5766176_B_db7.kaijutable.txt").text.contains("10239"),
                                file("$outputDir/kaiju/db7/2612_ERR5766176_B_db7.kaiju.tsv").getName() + " contains string 'ERR5766176.632060':" + file("$outputDir/kaiju/db7/2612_ERR5766176_B_db7.kaiju.tsv").text.contains("ERR5766176.632060"),
                                file("$outputDir/kaiju/db7/2612_ERR5766176_db7.kaijutable.txt").getName()+ " contains string '10239':" + file("$outputDir/kaiju/db7/2612_ERR5766176_db7.kaijutable.txt").text.contains("10239"),
                                file("$outputDir/kaiju/db7/2612_ERR5766176_db7.kaiju.tsv").getName() + " contains string 'ERR5766176.632059':" + file("$outputDir/kaiju/db7/2612_ERR5766176_db7.kaiju.tsv").text.contains("ERR5766176.632059"),
                                file("$outputDir/kaiju/db7/2612_ERR5766180_db7.kaijutable.txt").getName() + " contains string '10239':" + file("$outputDir/kaiju/db7/2612_ERR5766180_db7.kaijutable.txt").text.contains("10239"),
                                file("$outputDir/kaiju/db7/2612_ERR5766180_db7.kaiju.tsv").getName() + " contains string 'ERR5766180.801531':" + file("$outputDir/kaiju/db7/2612_ERR5766180_db7.kaiju.tsv").text.contains("ERR5766180.801531"),
                                file("$outputDir/kaiju/db7/2613_ERR5766181_db7.kaijutable.txt").getName() + " contains string '10239':" + file("$outputDir/kaiju/db7/2613_ERR5766181_db7.kaijutable.txt").text.contains("10239"),
                                file("$outputDir/kaiju/db7/2613_ERR5766181_db7.kaiju.tsv").getName() + " contains string 'ERR5766181.537544':" + file("$outputDir/kaiju/db7/2613_ERR5766181_db7.kaiju.tsv").text.contains("ERR5766181.537544"),
                                file("$outputDir/kaiju/db7/2614_ERR3201952_db7.kaijutable.txt").getName() + " contains string '10239':" + file("$outputDir/kaiju/db7/2614_ERR3201952_db7.kaijutable.txt").text.contains("10239"),
                                file("$outputDir/kaiju/db7/2614_ERR3201952_db7.kaiju.tsv").getName() + " contains string 'ERR3201952.3883730':" + file("$outputDir/kaiju/db7/2614_ERR3201952_db7.kaiju.tsv").text.contains("ERR3201952.3883730"),
                                file("$outputDir/kaiju/db7/ERR3201952_ERR3201952_db7.kaijutable.txt").getName() + " contains string '10239':" + file("$outputDir/kaiju/db7/ERR3201952_ERR3201952_db7.kaijutable.txt").text.contains("10239"),
                                file("$outputDir/kaiju/db7/ERR3201952_ERR3201952_db7.kaiju.tsv").getName() + " contains string 'ERR3201952.3334323':" + file("$outputDir/kaiju/db7/ERR3201952_ERR3201952_db7.kaiju.tsv").text.contains("ERR3201952.3334323"),
                        ).match("kaiju")
                },

                // kmcp
                { assert snapshot ( stable_content_kmcp ).match("kmcp") },

                // kraken2
                { assert snapshot (
                            file("$outputDir/kraken2/db2/2611_ERR5766174_db2.kraken2.kraken2.report.txt").getName() + " contains string:'Homo sapiens':" + file("$outputDir/kraken2/db2/2611_ERR5766174_db2.kraken2.kraken2.report.txt").text.contains("Homo sapiens"),
                            file("$outputDir/kraken2/db2/2612_ERR5766176_B_db2.kraken2.kraken2.report.txt").getName() + " contains string:'Saccharomyces cerevisiae S288C':" + file("$outputDir/kraken2/db2/2612_ERR5766176_B_db2.kraken2.kraken2.report.txt").text.contains("Saccharomyces cerevisiae S288C"),
                            file("$outputDir/kraken2/db2/2612_ERR5766176_db2.kraken2.kraken2.report.txt").getName() + " contains string:'Saccharomyces cerevisiae S288C':" + file("$outputDir/kraken2/db2/2612_ERR5766176_db2.kraken2.kraken2.report.txt").text.contains("Saccharomyces cerevisiae S288C"),
                            file("$outputDir/kraken2/db2/2612_ERR5766180_db2.kraken2.kraken2.report.txt").getName() + " contains string:'Saccharomyces cerevisiae S288C':" + file("$outputDir/kraken2/db2/2612_ERR5766180_db2.kraken2.kraken2.report.txt").text.contains("Saccharomyces cerevisiae S288C"),
                            file("$outputDir/kraken2/db2/2613_ERR5766181_db2.kraken2.kraken2.report.txt").getName() + " contains string:'Saccharomyces cerevisiae S288C':" + file("$outputDir/kraken2/db2/2613_ERR5766181_db2.kraken2.kraken2.report.txt").text.contains("Saccharomyces cerevisiae S288C"),
                    ).match("kraken2")
                },

                // melon
                { assert snapshot ( stable_content_melon ).match("melon") },

                // metacache
                { assert snapshot (
                                getAllFilesFromDir("$outputDir/metacache", include: ['**/*.txt']).collect { file -> file.getName() + " contains string 'Penicillium roqueforti': " + file.text.contains("Penicillium roqueforti")},
                        ).match("metacache")
                },

                // metaphlan
                { assert snapshot(
                                getAllFilesFromDir("$outputDir/metaphlan", include: ['**/*.metaphlan.biom']).collect { file -> file.getName() + " contains string 'generated_by': " + file.text.contains("generated_by")},
                                getAllFilesFromDir("$outputDir/metaphlan", include: ['**/*.metaphlan.bowtie2out.txt']).collect { file -> file.getName() + " contains string 'avg_read_length': " + file.text.contains("avg_read_length")},
                                getAllFilesFromDir("$outputDir/metaphlan", include: ['**/*_profile.txt']).collect { file -> file.getName() + " contains string 'clade_name': " + file.text.contains("clade_name")},
                                //metaphlan_sam_files.isEmpty() ? 'No SAM files' : metaphlan_sam_files.collect { file -> file.getName() + ":md5," + sam(file).getHeaderMD5() },
                        ).match("metaphlan")
                },

                // sylph
                { assert snapshot ( stable_content_sylph ).match("sylph") }


            )
        }
    }
}
